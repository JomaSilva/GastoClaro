# Copie este arquivo para .env.local e preencha as chaves necessárias.

# IA (obrigatório para processar gastos e gerar análises)
ANTHROPIC_API_KEY=

# Cotações alternativas (opcional)
BRAPI_TOKEN=your_brapi_token_here

# Pagamento real com Stripe (cartão + Google Pay).
# Sem esta chave, o app usa o checkout simulado automaticamente.
# Pegue em https://dashboard.stripe.com/apikeys (use sk_test_... para testes).
STRIPE_SECRET_KEY=

# Segredo do webhook da Stripe (whsec_...). Fonte de verdade do pagamento:
# garante a ativação do plano mesmo se o cliente não voltar ao site.
# Crie em https://dashboard.stripe.com/webhooks apontando para /api/checkout/webhook
# (evento checkout.session.completed). Em dev use `stripe listen --forward-to localhost:3000/api/checkout/webhook`.
STRIPE_WEBHOOK_SECRET=

# URL pública base do app (ex.: https://app.seudominio.com). Usada para montar as
# success_url/cancel_url do Stripe atrás de proxy. Opcional em localhost.
PUBLIC_BASE_URL=

# Login com a conta Google (Google Sign-In).
# Crie um OAuth Client ID (tipo "Web") em https://console.cloud.google.com/apis/credentials
# e adicione http://localhost:3000 às "Authorized JavaScript origins".
GOOGLE_CLIENT_ID=

# Conta de administrador (painel oculto em /admin).
# Padrão: adm / adm2070. Altere para algo seguro em produção.
ADMIN_EMAIL=adm
ADMIN_PASSWORD=adm2070
